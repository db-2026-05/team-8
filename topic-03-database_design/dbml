Table members {
  member_id integer [pk, increment]
  first_name varchar [not null]
  last_name varchar [not null]
  email varchar [not null, unique]
  phone_number varchar
  registration_date date
  status varchar
}

Table memberships {
  membership_id integer [pk, increment]
  member_id integer [not null, ref: > members.member_id]
  membership_type varchar
  start_date date
  end_date date
  price decimal
  status varchar
}

Table trainers {
  trainer_id integer [pk, increment]
  first_name varchar [not null]
  last_name varchar [not null]
  email varchar [unique]
  phone_number varchar
  bio text
}

Table specializations {
  specialization_id integer [pk, increment]
  name varchar [not null]
  description text
}

Table trainer_specializations {
  trainer_id integer [ref: > trainers.trainer_id]
  specialization_id integer [ref: > specializations.specialization_id]

  indexes {
    (trainer_id, specialization_id) [pk]
  }
}

Table trainer_availability {
  availability_id integer [pk, increment]
  trainer_id integer [not null, ref: > trainers.trainer_id]
  day_of_week varchar
  start_time time
  end_time time
}

Table classes {
  class_id integer [pk, increment]
  class_type varchar
  start_date date
  end_date date
  trainer_id integer [ref: > trainers.trainer_id]
}

Table schedules {
  schedule_id integer [pk, increment]
  class_id integer [not null, ref: > classes.class_id]
  day varchar
  time time
}

Table equipment {
  equipment_id integer [pk, increment]
  name varchar [not null]
  quantity integer
}

Table classes_equipment {
  class_id integer [ref: > classes.class_id]
  equipment_id integer [ref: > equipment.equipment_id]
  required_quantity integer [default: 1]

  indexes {
    (class_id, equipment_id) [pk]
  }
}

Table attendance {
  attendance_id integer [pk, increment]
  member_id integer [not null, ref: > members.member_id]
  class_id integer [not null, ref: > classes.class_id]
  attendance_date datetime
  status varchar
}

Table members_classes {
  member_id integer [ref: > members.member_id]
  class_id integer [ref: > classes.class_id]

  indexes {
    (member_id, class_id) [pk]
  }
}

Table personal_trainings {
  training_id integer [pk, increment]
  member_id integer [not null, ref: > members.member_id]
  trainer_id integer [not null, ref: > trainers.trainer_id]
  start_time datetime
  end_time datetime
  status varchar
}

Table goals {
  goal_id integer [pk, increment]
  member_id integer [not null, ref: > members.member_id]
  fitness_goal varchar
  achievement_date date
  status varchar
}

Table progress {
  progress_id integer [pk, increment]
  goal_id integer [not null, ref: > goals.goal_id]
  progress_metrics varchar
}
